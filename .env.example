# Power Automate HTTP trigger URL
# Create a flow: "When an HTTP request is received" -> "Post message in Teams channel"
# Paste the generated POST URL below.
TEAMS_WEBHOOK_URL=https://prod-xx.westeurope.logic.azure.com/workflows/...

# Public URL of the Spacio app (used in the Teams card "Book your desk" link)
APP_URL=http://localhost:5173

# Anthropic API key — enables the in-app AI booking agent.
# Get one at https://console.anthropic.com/. Leave blank to disable the agent
# (the /api/chat endpoint will return 503 and the chat widget will be hidden).
ANTHROPIC_API_KEY=
